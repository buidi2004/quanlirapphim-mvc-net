@{
    ViewData["Title"] = ViewBag.PageTitle;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var showtimes = ViewBag.Showtimes as IEnumerable<CinemaXNet.Models.Domain.Showtime>;
    var showDate = ViewBag.ShowDate as DateOnly?;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold text-warning mb-0"><i class="bi bi-calendar-event me-2"></i>Lịch Chiếu Toàn Quốc</h1>
    </div>

    <!-- Date Selector -->
    <div class="card bg-white border border-light p-3 rounded shadow-sm mb-4">
        <div class="d-flex overflow-auto custom-scrollbar gap-2 pb-2">
            @for (int i = 0; i < 14; i++)
            {
                var d = DateOnly.FromDateTime(DateTime.Today).AddDays(i);
                var isSelected = d == showDate;
                <a href="?date=@d.ToString("yyyy-MM-dd")" 
                   class="btn @(isSelected ? "btn-warning fw-bold shadow-sm" : "btn-outline-secondary") flex-shrink-0 px-4 py-2 rounded-pill">
                    @d.ToString("dd/MM")
                </a>
            }
        </div>
    </div>

    @if (showtimes == null || !showtimes.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-film text-secondary display-1 mb-3"></i>
            <p class="text-secondary fs-5 fst-italic">Không có suất chiếu nào trong ngày @(showDate?.ToString("dd/MM/yyyy")).</p>
        </div>
    }
    else
    {
        // Group by Province -> Cinema -> Movie
        var groupedByProvince = showtimes.GroupBy(s => s.Room?.Cinema?.Province ?? "Khác");
        
        <div class="row g-4">
            <!-- Left Sidebar: Jump links to provinces -->
            <div class="col-md-3 d-none d-md-block">
                <div class="sticky-top rounded shadow-sm bg-white p-3 border border-light" style="top: 80px;">
                    <h6 class="text-dark fw-bold mb-3 border-bottom pb-2">Khu Vực</h6>
                    <div class="list-group list-group-flush">
                        @foreach (var pGroup in groupedByProvince)
                        {
                            <a href="#province-@pGroup.Key.Replace(" ", "-")" class="list-group-item list-group-item-action text-dark border-0">
                                @pGroup.Key
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Right Content: Showtimes -->
            <div class="col-md-9">
                @foreach (var provinceGroup in groupedByProvince)
                {
                    <h4 id="province-@provinceGroup.Key.Replace(" ", "-")" class="text-warning fw-bold border-bottom border-warning pb-2 mb-4 mt-2">
                        @provinceGroup.Key
                    </h4>
                    
                    var groupedByCinema = provinceGroup.GroupBy(s => s.Room?.Cinema);
                    
                    @foreach (var cinemaGroup in groupedByCinema)
                    {
                        var cinema = cinemaGroup.Key;
                        <div class="card bg-white border border-light shadow-sm rounded-4 mb-4 overflow-hidden">
                            <div class="card-header bg-light border-bottom border-light p-3">
                                <h5 class="text-dark fw-bold mb-0">
                                    <i class="bi bi-building me-2 text-warning"></i>@(cinema?.Name ?? "Rạp Khác")
                                </h5>
                                @if (cinema != null)
                                {
                                    <small class="text-secondary"><i class="bi bi-geo-alt me-1"></i>@cinema.GetFullAddress()</small>
                                }
                            </div>
                            <div class="card-body p-0">
                                @{
                                    var groupedByMovie = cinemaGroup.GroupBy(s => s.Movie);
                                }
                                <ul class="list-group list-group-flush">
                                    @foreach (var movieGroup in groupedByMovie)
                                    {
                                        var movie = movieGroup.Key;
                                        <li class="list-group-item bg-white p-4">
                                            <div class="row">
                                                <div class="col-md-3 mb-3 mb-md-0">
                                                    <h6 class="text-dark fw-bold mb-1">@movie?.Title</h6>
                                                    <div class="text-secondary small">
                                                        <i class="bi bi-clock me-1"></i>@(movie?.DurationMinutes) phút
                                                        @if (movie?.AgeRating != null)
                                                        {
                                                            <span class="badge bg-danger ms-2">@movie.AgeRating</span>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="col-md-9">
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var st in movieGroup)
                                                        {
                                                            <a href="/booking/seats?showtimeId=@st.Id" class="btn btn-outline-warning btn-sm text-dark shadow-sm">
                                                                <div class="fw-bold fs-6">@st.StartTime</div>
                                                                <small style="font-size: 0.75rem;">@string.Format("{0:N0}đ", st.Price)</small>
                                                            </a>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<style>
.custom-scrollbar::-webkit-scrollbar {
    height: 6px;
}
.custom-scrollbar::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
    background: #ffc107;
    border-radius: 4px;
}
</style>
