@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Nhật ký hệ thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentEntity = ViewBag.CurrentEntity as string;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom border-light">
    <h1 class="h2 text-warning fw-bold">Nhật ký hệ thống (Audit Logs)</h1>
</div>

<div class="card bg-white border border-light rounded shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2">
            <select name="entityName" class="form-select w-auto">
                <option value="">Tất cả Entity</option>
                <option value="Movie" selected="@(currentEntity == "Movie")">Phim</option>
                <option value="Room" selected="@(currentEntity == "Room")">Phòng chiếu</option>
                <option value="FoodBeverage" selected="@(currentEntity == "FoodBeverage")">Bắp nước</option>
                <option value="MarketingCampaign" selected="@(currentEntity == "MarketingCampaign")">Chiến dịch</option>
                <option value="PricingRule" selected="@(currentEntity == "PricingRule")">Luật giá</option>
            </select>
            <button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Lọc</button>
        </form>
    </div>
</div>

<div class="card bg-white border border-light rounded shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead class="text-uppercase" style="background-color: #111;">
                <tr>
                    <th scope="col">Thời gian</th>
                    <th scope="col">Người dùng</th>
                    <th scope="col">Hành động</th>
                    <th scope="col">Entity</th>
                    <th scope="col">ID Entity</th>
                    <th scope="col">Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">Chưa có nhật ký nào.</td></tr>
                }
                else
                {
                    foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.created_at</td>
                            <td><span class="badge bg-secondary">@log.Username</span> @log.FullName</td>
                            <td>
                                @if(log.action == "Create") { <span class="badge bg-success">Tạo mới</span> }
                                else if(log.action == "Update") { <span class="badge bg-info">Cập nhật</span> }
                                else if(log.action == "Delete") { <span class="badge bg-danger">Xóa</span> }
                                else { <span class="badge bg-light text-dark">@log.action</span> }
                            </td>
                            <td>@log.entity_name</td>
                            <td>@log.entity_id</td>
                            <td><small class="text-secondary">@log.details</small></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
