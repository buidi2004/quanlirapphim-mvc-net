@{
    ViewData["Title"] = "Lịch sử giao dịch";
    var transactions = ViewBag.Transactions as IEnumerable<dynamic> ?? [];
    var totalSpent   = (decimal)(ViewBag.TotalSpent ?? 0);
    var filter       = ViewBag.Filter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h5 text-warning mb-0">
        <i class="bi bi-clock-history me-2"></i>Lịch sử giao dịch
    </h1>
    <div class="d-flex gap-2">
        <a href="/profile/transactions" class="btn btn-sm @(filter == null ? "btn-warning" : "btn-outline-secondary")">Tất cả</a>
        <a href="/profile/transactions?status=paid"      class="btn btn-sm @(filter=="paid"      ? "btn-success" : "btn-outline-secondary")">Đã TT</a>
        <a href="/profile/transactions?status=holding"   class="btn btn-sm @(filter=="holding"   ? "btn-warning" : "btn-outline-secondary")">Đang giữ</a>
        <a href="/profile/transactions?status=cancelled" class="btn btn-sm @(filter=="cancelled" ? "btn-danger"  : "btn-outline-secondary")">Đã hủy</a>
    </div>
</div>

@if (totalSpent > 0)
{
    <div class="alert alert-dark border border-warning border-opacity-25 mb-4">
        <i class="bi bi-wallet2 me-2 text-warning"></i>
        Tổng đã chi: <strong class="text-warning">@totalSpent.ToString("N0")đ</strong>
    </div>
}

@if (!transactions.Any())
{
    <div class="text-center py-5 text-secondary">
        <i class="bi bi-receipt" style="font-size:3rem;"></i>
        <p class="mt-3">Chưa có giao dịch nào.</p>
        <a href="/movies" class="btn btn-warning mt-2">Đặt vé ngay</a>
    </div>
}
else
{
    <div class="card bg-white border-light">
        <div class="list-group list-group-flush">
            @foreach (var t in transactions)
            {
                var badgeCls = t.status == "paid"      ? "bg-success"
                             : t.status == "holding"   ? "bg-warning text-dark"
                             : "bg-secondary";
                var statusLbl = t.status == "paid"      ? "Đã thanh toán"
                              : t.status == "holding"   ? "Đang giữ"
                              : "Đã hủy";
                <div class="list-group-item bg-transparent border-light py-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <strong class="text-dark">@t.MovieTitle</strong>
                            <div class="text-secondary small mt-1">
                                <i class="bi bi-calendar3 me-1"></i>@t.ShowDate
                                <i class="bi bi-clock ms-2 me-1"></i>@t.StartTime
                                <i class="bi bi-door-closed ms-2 me-1"></i>@t.RoomName
                                · Ghế <span class="text-warning">@t.SeatCode</span>
                            </div>
                            @if (t.PromotionCode != null)
                            {
                                <small class="text-success"><i class="bi bi-tag me-1"></i>Mã: @t.PromotionCode</small>
                            }
                        </div>
                        <div class="text-end">
                            <span class="badge @badgeCls mb-1">@statusLbl</span>
                            <div class="text-warning fw-bold">@((decimal)t.TotalPrice).ToString("N0")đ</div>
                            <div class="text-secondary" style="font-size:.7rem;">@t.BookedAt</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="mt-3">
    <a href="/profile" class="text-secondary text-decoration-none small">
        <i class="bi bi-arrow-left me-1"></i>Quay lại hồ sơ
    </a>
</div>
