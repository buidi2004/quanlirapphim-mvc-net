@model CinemaXNet.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card bg-white border-light shadow">
            <div class="card-body p-4">
                <h1 class="h5 text-warning mb-4">
                    <i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu
                </h1>

                @if (!string.IsNullOrEmpty(Model.GeneralError))
                {
                    <div class="alert alert-danger border-0 small">
                        <i class="bi bi-exclamation-triangle me-1"></i>@Model.GeneralError
                    </div>
                }

                <form method="post" action="/profile/change-password">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label text-secondary small">Mật khẩu hiện tại</label>
                        <input type="password" name="CurrentPassword"
                               class="form-control bg-light border-light text-dark"
                               placeholder="••••••••" required>
                        @if (ViewData.ModelState["CurrentPassword"]?.Errors.Any() == true)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["CurrentPassword"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Mật khẩu mới</label>
                        <input type="password" name="NewPassword"
                               class="form-control bg-light border-light text-dark"
                               placeholder="Ít nhất 8 ký tự" required minlength="8">
                        @if (ViewData.ModelState["NewPassword"]?.Errors.Any() == true)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["NewPassword"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary small">Xác nhận mật khẩu mới</label>
                        <input type="password" name="ConfirmPassword"
                               class="form-control bg-light border-light text-dark"
                               placeholder="Nhập lại mật khẩu mới" required>
                        @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["ConfirmPassword"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Đổi mật khẩu
                        </button>
                        <a href="/profile" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
