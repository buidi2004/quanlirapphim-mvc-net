<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewBag.PageTitle ?? "CinemaX Admin Dashboard")</title>

    <!-- Bootstrap 5.3 Dark Mode -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/css/app.css">
</head>
<body class="bg-light text-dark min-vh-100 d-flex flex-column">

    <!-- Navbar -->
    @await Html.PartialAsync("_Navbar")

    <div class="container-fluid flex-grow-1 d-flex">
        <div class="row w-100 flex-grow-1">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 bg-white border-end border-light py-4 sidebar">
                <div class="position-sticky">
                    <ul class="nav flex-column gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/dashboard") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/dashboard">
                                <i class="bi bi-speedometer2 me-2"></i> Thống kê chung
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/movies") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/movies">
                                <i class="bi bi-film me-2"></i> Quản lý phim
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/showtimes") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/showtimes">
                                <i class="bi bi-clock me-2"></i> Suất Chiếu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/tickets") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/tickets">
                                <i class="bi bi-ticket-perforated me-2"></i> Đơn Vé
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/food-beverages") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/food-beverages">
                                <i class="bi bi-cup-straw me-2"></i> Bắp Nước
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/promotions") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/promotions">
                                <i class="bi bi-tags me-2"></i> Khuyến Mãi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/news") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/news">
                                <i class="bi bi-newspaper me-2"></i> Tin Tức
                            </a>
                        </li>
                        <li class="nav-item mt-3">
                            <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase">
                                <span>Hoạt Động Trực Tiếp</span>
                            </h6>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/pos") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/pos">
                                <i class="bi bi-display me-2"></i> POS Bán Vé
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/scanner") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/scanner">
                                <i class="bi bi-qr-code-scan me-2"></i> Quét Vé Check-in
                            </a>
                        </li>
                        <li class="nav-item mt-3">
                            <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase">
                                <span>Khách Hàng</span>
                            </h6>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/users") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/users">
                                <i class="bi bi-people me-2"></i> Người Dùng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/reviews") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/reviews">
                                <i class="bi bi-star-half me-2"></i> Đánh Giá
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/contacts") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/contacts">
                                <i class="bi bi-envelope-paper me-2"></i> Liên Hệ
                            </a>
                        </li>
                        <li class="nav-item mt-3">
                            <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase">
                                <span>Hệ Thống</span>
                            </h6>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/reports") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/reports">
                                <i class="bi bi-graph-up me-2"></i> Báo Cáo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/settings") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/settings">
                                <i class="bi bi-gear me-2"></i> Cấu Hình
                            </a>
                        </li>
                        <li class="nav-item mt-3">
                            <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase">
                                <span>Mở Rộng & CRM</span>
                            </h6>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/audit-logs") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/audit-logs">
                                <i class="bi bi-journal-text me-2"></i> Nhật Ký (Audit)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/membership") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/membership">
                                <i class="bi bi-star me-2"></i> Hạng Thành Viên
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/pricing-rules") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/pricing-rules">
                                <i class="bi bi-currency-dollar me-2"></i> Luật Giá Vé
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(Context.Request.Path.StartsWithSegments("/admin/campaigns") ? "active bg-warning text-dark fw-bold rounded" : "")" href="/admin/campaigns">
                                <i class="bi bi-megaphone me-2"></i> Chiến Dịch Marketing
                            </a>
                        </li>
                        <li class="nav-item mt-4">
                            <a class="nav-link text-secondary p-2 d-flex align-items-center gap-2 rounded hover-bg" href="/">
                                <i class="bi bi-arrow-left"></i>
                                Về Trang chủ
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Panel Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 bg-light">
                <!-- Flash Messages -->
                @await Html.PartialAsync("_FlashMessage")

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white text-secondary text-center py-3 border-top border-light">
        <small>&copy; @DateTime.Now.Year CinemaX. Admin Panel.</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
