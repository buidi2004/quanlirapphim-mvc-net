@model CinemaXNet.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card bg-white border border-light shadow-lg">
            <div class="card-body p-4">
                <h1 class="h4 text-center text-warning mb-1">
                    <i class="bi bi-shield-lock me-2"></i>Đặt lại mật khẩu
                </h1>
                <p class="text-secondary text-center small mb-4">Nhập mật khẩu mới của bạn</p>

                @if (!string.IsNullOrEmpty(Model.GeneralError))
                {
                    <div class="alert alert-danger border-0 small">
                        <i class="bi bi-exclamation-triangle me-2"></i>@Model.GeneralError
                    </div>
                }

                <form method="post" action="/reset-password">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Token" value="@Model.Token">

                    <div class="mb-3">
                        <label class="form-label text-secondary small">Mật khẩu mới</label>
                        <input type="password" name="Password"
                               class="form-control bg-light border-light text-dark"
                               placeholder="Ít nhất 6 ký tự" required minlength="6">
                        @if (ViewData.ModelState["Password"]?.Errors.Any() == true)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["Password"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-secondary small">Xác nhận mật khẩu</label>
                        <input type="password" name="ConfirmPassword"
                               class="form-control bg-light border-light text-dark"
                               placeholder="Nhập lại mật khẩu mới" required>
                        @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["ConfirmPassword"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">
                        <i class="bi bi-check-lg me-2"></i>Đặt lại mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
