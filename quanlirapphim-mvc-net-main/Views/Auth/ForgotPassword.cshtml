@{
    ViewData["Title"] = "Quên mật khẩu";
    var vm = Model as CinemaXNet.ViewModels.ForgotPasswordViewModel ?? new();
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card bg-white border border-light shadow-lg">
            <div class="card-body p-4">
                <h1 class="h4 text-center text-warning mb-1">
                    <i class="bi bi-key me-2"></i>Quên mật khẩu
                </h1>
                <p class="text-secondary text-center small mb-4">
                    Nhập email, chúng tôi sẽ gửi link đặt lại mật khẩu
                </p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    </div>
                }

                <form method="post" action="/forgot-password">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label text-secondary small">Email</label>
                        <input type="email" name="email" value="@vm.Email"
                               class="form-control bg-light border-light text-dark"
                               placeholder="you@example.com" required autofocus>
                        @if (!string.IsNullOrEmpty(ViewData.ModelState["Email"]?.Errors.FirstOrDefault()?.ErrorMessage))
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["Email"]!.Errors.First().ErrorMessage</div>
                        }
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">
                        <i class="bi bi-send me-2"></i>Gửi link đặt lại
                    </button>
                </form>

                <hr class="border-light my-3">
                <div class="text-center">
                    <a href="/login" class="text-warning small">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
