@{
    ViewData["Title"] = "POS - Bán vé tại quầy";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .movie-item { cursor: pointer; transition: 0.2s; }
    .movie-item:hover { background-color: #f8f9fa; }
    .movie-item.active { background-color: #e3f2fd; border-color: #0d6efd !important; }
    .showtime-btn { cursor: pointer; }
    .seat { 
        width: 35px; height: 35px; 
        margin: 3px; 
        display: inline-flex; 
        align-items: center; 
        justify-content: center; 
        border-radius: 5px;
        font-size: 12px;
        font-weight: bold;
        cursor: pointer;
    }
    .seat.available { background-color: #e9ecef; border: 1px solid #ced4da; }
    .seat.selected { background-color: #0d6efd; color: white; border: 1px solid #0a58ca; }
    .seat.unavailable { background-color: #dc3545; color: white; border: 1px solid #b02a37; cursor: not-allowed; }
    .seat-row { display: flex; justify-content: center; margin-bottom: 5px; }
    .screen { 
        background: linear-gradient(to bottom, #ced4da, #f8f9fa);
        height: 30px; 
        border-top-left-radius: 50%; 
        border-top-right-radius: 50%;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #6c757d;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800"><i class="bi bi-display me-2 text-primary"></i>POS - Bán vé tại quầy</h1>
</div>

<div class="row">
    <!-- Cột 1: Chọn Phim & Suất chiếu -->
    <div class="col-md-3">
        <div class="card shadow mb-4 h-100">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">1. Chọn Phim & Suất chiếu</h6>
            </div>
            <div class="card-body" style="max-height: 600px; overflow-y: auto;" id="movieList">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột 2: Sơ đồ ghế -->
    <div class="col-md-6">
        <div class="card shadow mb-4 h-100">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">2. Sơ đồ ghế</h6>
            </div>
            <div class="card-body text-center" id="seatMapContainer">
                <p class="text-muted mt-5">Vui lòng chọn suất chiếu để hiện sơ đồ ghế.</p>
            </div>
        </div>
    </div>

    <!-- Cột 3: Thanh toán -->
    <div class="col-md-3">
        <div class="card shadow mb-4 h-100">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">3. Thanh toán</h6>
            </div>
            <div class="card-body d-flex flex-column">
                <div id="checkoutSummary" class="flex-grow-1">
                    <p class="text-muted">Chưa có vé nào được chọn.</p>
                </div>
                
                <hr>
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="m-0">Tổng tiền:</h5>
                    <h5 class="m-0 text-danger font-weight-bold" id="totalPrice">0 ₫</h5>
                </div>
                
                <button class="btn btn-success btn-lg w-100 mb-2" id="btnCheckout" disabled>
                    <i class="bi bi-cash me-2"></i>Thu tiền mặt (Thanh toán)
                </button>
                <button class="btn btn-outline-secondary w-100" id="btnReset" onclick="resetPos()">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Làm lại
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentMovieId = null;
        let currentShowtimeId = null;
        let currentPrice = 0;
        let selectedSeats = [];

        document.addEventListener('DOMContentLoaded', () => {
            loadMovies();
        });

        async function loadMovies() {
            try {
                const res = await fetch('/admin/pos/api/movies');
                const movies = await res.json();
                
                const container = document.getElementById('movieList');
                container.innerHTML = '';
                
                if (movies.length === 0) {
                    container.innerHTML = '<p class="text-muted text-center">Không có phim nào đang chiếu.</p>';
                    return;
                }

                movies.forEach(m => {
                    const el = document.createElement('div');
                    el.className = 'card mb-2 movie-item border';
                    el.onclick = () => selectMovie(m.id, el);
                    el.innerHTML = `
                        <div class="card-body p-2 d-flex">
                            <img src="${m.posterUrl}" style="width: 50px; height: 75px; object-fit: cover;" class="rounded me-2">
                            <div>
                                <h6 class="mb-1 font-weight-bold">${m.title}</h6>
                                <span class="badge bg-secondary">${m.ageRating}</span>
                            </div>
                        </div>
                        <div class="showtimes-container p-2 bg-light border-top d-none" id="showtimes-${m.id}"></div>
                    `;
                    container.appendChild(el);
                });
            } catch (error) {
                console.error(error);
                alert("Lỗi khi tải danh sách phim!");
            }
        }

        async function selectMovie(movieId, element) {
            document.querySelectorAll('.movie-item').forEach(el => {
                el.classList.remove('active');
                el.querySelector('.showtimes-container').classList.add('d-none');
            });
            element.classList.add('active');
            
            const showtimeContainer = document.getElementById(`showtimes-${movieId}`);
            showtimeContainer.classList.remove('d-none');
            showtimeContainer.innerHTML = '<div class="spinner-border spinner-border-sm text-primary"></div>';

            currentMovieId = movieId;
            
            try {
                const res = await fetch(`/admin/pos/api/showtimes/${movieId}`);
                const data = await res.json();
                
                showtimeContainer.innerHTML = '';
                
                if (Object.keys(data).length === 0) {
                    showtimeContainer.innerHTML = '<small class="text-muted">Không có suất chiếu.</small>';
                    return;
                }

                for (const [date, showtimes] of Object.entries(data)) {
                    let dateHtml = `<div class="mb-1 fw-bold" style="font-size:12px;">${date}</div><div class="d-flex flex-wrap gap-1 mb-2">`;
                    showtimes.forEach(st => {
                        dateHtml += `<button class="btn btn-sm btn-outline-primary py-0 px-2 showtime-btn" onclick="event.stopPropagation(); loadSeatMap(${st.id}, ${st.price})">${st.startTime.substring(0,5)}</button>`;
                    });
                    dateHtml += `</div>`;
                    showtimeContainer.innerHTML += dateHtml;
                }
            } catch (error) {
                console.error(error);
                showtimeContainer.innerHTML = '<small class="text-danger">Lỗi tải suất chiếu.</small>';
            }
        }

        async function loadSeatMap(showtimeId, price) {
            currentShowtimeId = showtimeId;
            currentPrice = price;
            selectedSeats = [];
            updateCheckout();

            const container = document.getElementById('seatMapContainer');
            container.innerHTML = '<div class="spinner-border text-primary my-5"></div>';

            try {
                const res = await fetch(`/admin/pos/api/seatmap/${showtimeId}`);
                const data = await res.json();
                
                let html = `
                    <div class="screen mb-4">MÀN HÌNH</div>
                    <div class="seat-map-wrapper" style="overflow-x: auto;">
                `;

                if (data.layoutJson && data.layoutJson.trim() !== '') {
                    try {
                        const layout = JSON.parse(data.layoutJson);
                        html += `<div style="display: grid; gap: 5px; justify-content: center; grid-template-columns: repeat(${data.seatsPerRow}, auto);">`;
                        for (let r = 0; r < layout.length; r++) {
                            for (let c = 0; c < layout[r].length; c++) {
                                const seat = layout[r][c];
                                if (seat.type === 'couple_right') continue;

                                if (seat.type === 'hidden') {
                                    html += `<div style="width: 35px; height: 35px;"></div>`;
                                } else {
                                    const status = data.seatStatuses[seat.id] || 'available';
                                    let statusClass = status === 'available' ? 'available' : 'unavailable';
                                    let extraStyle = '';
                                    
                                    if (seat.type === 'vip') {
                                        extraStyle = 'border: 2px solid #ffc107;';
                                    } else if (seat.type === 'couple') {
                                        extraStyle = 'grid-column: span 2; width: 75px; background-color: #e83e8c; color: white; border: none;';
                                        if(statusClass === 'available') statusClass = '';
                                    } else if (seat.type === 'broken') {
                                        statusClass = 'unavailable';
                                        extraStyle = 'opacity: 0.5; background-color: #dc3545; color: white;';
                                    }

                                    html += `<div class="seat ${statusClass}" style="${extraStyle}"
                                                  data-code="${seat.id}" 
                                                  ${status === 'available' && seat.type !== 'broken' ? `onclick="toggleSeat('${seat.id}', this)"` : ''}>
                                                ${seat.id}
                                             </div>`;
                                }
                            }
                        }
                        html += `</div>`;
                    } catch(e) {
                        console.error('Error parsing layout_json', e);
                    }
                } else {
                    const rowLetters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
                    for (let r = 0; r < data.totalRows; r++) {
                        const rowLabel = r < rowLetters.length ? rowLetters[r] : r.toString();
                        html += `<div class="seat-row">
                            <div style="width: 25px; line-height: 35px; font-weight: bold; margin-right: 10px;">${rowLabel}</div>
                        `;
                        for (let c = 0; c < data.seatsPerRow; c++) {
                            const code = `${rowLabel}${c+1}`;
                            const status = data.seatStatuses[code] || 'available';
                            let statusClass = status === 'available' ? 'available' : 'unavailable';
                            
                            html += `<div class="seat ${statusClass}" 
                                          data-code="${code}" 
                                          ${status === 'available' ? `onclick="toggleSeat('${code}', this)"` : ''}>
                                        ${c+1}
                                     </div>`;
                        }
                        html += `</div>`;
                    }
                }

                html += `</div>
                    <div class="mt-4 d-flex justify-content-center flex-wrap gap-3">
                        <div><div class="seat available d-inline-block align-middle m-0"></div> Trống</div>
                        <div><div class="seat selected d-inline-block align-middle m-0"></div> Đang chọn</div>
                        <div><div class="seat unavailable d-inline-block align-middle m-0"></div> Đã bán</div>
                        <div><div class="seat d-inline-block align-middle m-0" style="border: 2px solid #ffc107;"></div> VIP</div>
                        <div><div class="seat d-inline-block align-middle m-0" style="width:75px; background-color: #e83e8c;"></div> Couple</div>
                    </div>
                `;
                
                container.innerHTML = html;
                
            } catch (error) {
                console.error(error);
                container.innerHTML = '<p class="text-danger">Lỗi khi tải sơ đồ ghế.</p>';
            }
        }

        function toggleSeat(code, element) {
            if (element.classList.contains('unavailable')) return;
            
            if (element.classList.contains('selected')) {
                element.classList.remove('selected');
                selectedSeats = selectedSeats.filter(s => s !== code);
            } else {
                element.classList.add('selected');
                selectedSeats.push(code);
            }
            updateCheckout();
        }

        function updateCheckout() {
            const summary = document.getElementById('checkoutSummary');
            const totalEl = document.getElementById('totalPrice');
            const btnCheckout = document.getElementById('btnCheckout');
            
            if (selectedSeats.length === 0) {
                summary.innerHTML = '<p class="text-muted">Chưa có vé nào được chọn.</p>';
                totalEl.innerText = '0 ₫';
                btnCheckout.disabled = true;
                return;
            }

            let total = selectedSeats.length * currentPrice;
            
            let html = `
                <div class="mb-3">
                    <strong>Ghế đã chọn:</strong>
                    <div class="mt-1">
                        ${selectedSeats.map(s => `<span class="badge bg-primary me-1 fs-6">${s}</span>`).join('')}
                    </div>
                </div>
                <div class="mb-3">
                    <strong>Đơn giá:</strong> ${new Intl.NumberFormat('vi-VN').format(currentPrice)} ₫
                </div>
                <div class="mb-3">
                    <strong>Số lượng:</strong> ${selectedSeats.length} vé
                </div>
            `;
            
            summary.innerHTML = html;
            totalEl.innerText = new Intl.NumberFormat('vi-VN').format(total) + ' ₫';
            btnCheckout.disabled = false;
        }

        function resetPos() {
            currentMovieId = null;
            currentShowtimeId = null;
            selectedSeats = [];
            document.getElementById('seatMapContainer').innerHTML = '<p class="text-muted mt-5">Vui lòng chọn suất chiếu để hiện sơ đồ ghế.</p>';
            updateCheckout();
            loadMovies();
        }

        document.getElementById('btnCheckout').addEventListener('click', async () => {
            if (!currentShowtimeId || selectedSeats.length === 0) return;
            
            const btn = document.getElementById('btnCheckout');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            
            try {
                const res = await fetch('/admin/pos/api/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        showtimeId: currentShowtimeId,
                        seatCodes: selectedSeats
                    })
                });
                
                const result = await res.json();
                
                if (res.ok && result.success) {
                    alert('Thanh toán thành công! Đã xuất ' + selectedSeats.length + ' vé.');
                    resetPos();
                } else {
                    alert('Lỗi: ' + (result.error || 'Thanh toán thất bại'));
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-cash me-2"></i>Thu tiền mặt (Thanh toán)';
                }
            } catch (error) {
                console.error(error);
                alert('Lỗi kết nối khi thanh toán!');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-cash me-2"></i>Thu tiền mặt (Thanh toán)';
            }
        });
    </script>
}
