@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex flex-column align-items-center justify-content-center text-center py-5" style="min-height: 70vh;">
    <div class="position-relative mb-4">
        <!-- Rạp phim trống -->
        <i class="bi bi-camera-reels text-secondary opacity-25" style="font-size: 8rem;"></i>
        <div class="position-absolute top-50 start-50 translate-middle">
            <h1 class="display-1 fw-bold text-warning mb-0" style="text-shadow: 2px 2px 8px rgba(255,193,7,0.3);">404</h1>
        </div>
    </div>
    
    <h2 class="text-white fw-bold mb-3">Rất tiếc, phòng chiếu này không tồn tại!</h2>
    <p class="text-secondary fs-5 mb-5 max-w-md mx-auto">
        Trang bạn đang tìm kiếm có thể đã bị xóa, đổi tên hoặc không bao giờ tồn tại trong vũ trụ điện ảnh của chúng tôi.
    </p>
    
    <div class="d-flex gap-3">
        <button onclick="history.back()" class="btn btn-outline-secondary btn-lg fw-bold px-4">
            <i class="bi bi-arrow-left me-2"></i>Quay lại
        </button>
        <a href="/" class="btn btn-warning btn-lg fw-bold px-4 shadow-sm">
            <i class="bi bi-house-door me-2"></i>Về Trang chủ
        </a>
    </div>
</div>

<style>
    .max-w-md { max-width: 600px; }
</style>
