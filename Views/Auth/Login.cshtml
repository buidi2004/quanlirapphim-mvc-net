@model CinemaXNet.Application.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 col-lg-5 col-xl-4">
        <div class="card bg-white border border-light p-4 rounded shadow-lg">
            <h2 class="text-center text-warning fw-medium mb-4">ĐĂNG NHẬP</h2>

                @if (!string.IsNullOrEmpty(Model.GeneralError))
                {
                    <div class="alert alert-danger border-0 p-2 text-center mb-3" style="background-color: rgba(220, 53, 69, 0.2); color: #f8d7da;">
                        <small>@Model.GeneralError</small>
                    </div>
                }

                <form method="post" action="/login@(ViewBag.ReturnUrl != null ? "?returnUrl=" + Uri.EscapeDataString(ViewBag.ReturnUrl) : "")">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label text-dark">Email / Tên đăng nhập</label>
                        <input type="text" name="Email"
                               class="form-control bg-white bg-opacity-50 text-dark border-light @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="admin hoặc name@example.com"
                               value="@Model.Email" required>
                        <span asp-validation-for="Email" class="invalid-feedback text-purple"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-dark">Mật khẩu</label>
                        <input type="password" name="Password"
                               class="form-control bg-white bg-opacity-50 text-dark border-light @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Mật khẩu" required>
                        <span asp-validation-for="Password" class="invalid-feedback text-purple"></span>
                    </div>

                <button type="submit" class="btn btn-warning w-100 fw-medium py-2 shadow mb-3">
                    ĐĂNG NHẬP
                </button>

                    <div class="d-flex align-items-center mb-3">
                        <hr class="flex-grow-1 border-light">
                        <span class="mx-2 text-dark small opacity-75">HOẶC</span>
                        <hr class="flex-grow-1 border-light">
                    </div>

                    <div class="d-grid gap-2 mb-4">
                        <a href="/auth/google-login" class="btn btn-outline-dark fw-semibold rounded-pill">
                            <i class="bi bi-google text-danger me-2"></i> Đăng nhập bằng Google
                        </a>
                        <a href="/auth/facebook-login" class="btn btn-outline-dark fw-semibold rounded-pill">
                            <i class="bi bi-facebook text-primary me-2"></i> Đăng nhập bằng Facebook
                        </a>
                    </div>

                    <p class="text-center text-dark small mb-0 opacity-75">
                        Chưa có tài khoản? <a href="/register" class="text-purple text-decoration-none fw-bold">Đăng ký ngay</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>
