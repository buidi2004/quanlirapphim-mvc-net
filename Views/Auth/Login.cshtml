@model CinemaXNet.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 col-lg-5 col-xl-4">
        <div class="card bg-white border border-light p-4 rounded shadow-lg">
            <h2 class="text-center text-warning fw-bold mb-4">ĐĂNG NHẬP</h2>

            @if (!string.IsNullOrEmpty(Model.GeneralError))
            {
                <div class="alert alert-danger border-0 p-2 text-center mb-3" style="background-color: #3b171c; color: #f8d7da;">
                    <small>@Model.GeneralError</small>
                </div>
            }

            <form method="post" action="/login@(ViewBag.ReturnUrl != null ? "?returnUrl=" + Uri.EscapeDataString(ViewBag.ReturnUrl) : "")">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label text-dark">Email</label>
                    <input type="email" name="Email"
                           class="form-control bg-light text-dark border-light @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="name@example.com"
                           value="@Model.Email" required>
                    <span asp-validation-for="Email" class="invalid-feedback"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dark">Mật khẩu</label>
                    <input type="password" name="Password"
                           class="form-control bg-light text-dark border-light @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Mật khẩu" required>
                    <span asp-validation-for="Password" class="invalid-feedback"></span>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow mb-3">
                    ĐĂNG NHẬP
                </button>

                <div class="d-flex align-items-center mb-3">
                    <hr class="flex-grow-1 border-secondary">
                    <span class="mx-2 text-secondary small">HOẶC</span>
                    <hr class="flex-grow-1 border-secondary">
                </div>

                <div class="d-grid gap-2 mb-4">
                    <a href="/auth/google-login" class="btn btn-outline-danger fw-semibold">
                        <i class="bi bi-google me-2"></i> Đăng nhập bằng Google
                    </a>
                    <a href="/auth/facebook-login" class="btn btn-outline-primary fw-semibold">
                        <i class="bi bi-facebook me-2"></i> Đăng nhập bằng Facebook
                    </a>
                </div>

                <p class="text-center text-secondary small mb-0">
                    Chưa có tài khoản? <a href="/register" class="text-warning text-decoration-none fw-semibold">Đăng ký ngay</a>
                </p>
            </form>
        </div>
    </div>
</div>
