@{
    ViewData["Title"] = "Liên hệ & Hỗ trợ";
}

<div class="row g-5">
    <!-- Contact Form -->
    <div class="col-md-7">
        <h1 class="h4 text-warning border-start border-warning border-4 ps-3 fw-bold mb-4">
            <i class="bi bi-envelope-fill me-2"></i>GỬI YÊU CẦU HỖ TRỢ
        </h1>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 mb-4">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            </div>
        }

        <div class="card bg-white border-light shadow p-4">
            <form method="post" action="/contact">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Họ và tên *</label>
                        <input type="text" name="name" class="form-control bg-light border-light text-dark"
                               placeholder="Nguyễn Văn A" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Email *</label>
                        <input type="email" name="email" class="form-control bg-light border-light text-dark"
                               placeholder="you@example.com" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-secondary small">Chủ đề</label>
                        <select name="subject" class="form-select bg-light border-light text-dark">
                            <option value="">-- Chọn chủ đề --</option>
                            <option value="Đặt vé">Vấn đề đặt vé</option>
                            <option value="Thanh toán">Vấn đề thanh toán</option>
                            <option value="Hoàn tiền">Yêu cầu hoàn tiền</option>
                            <option value="Tài khoản">Vấn đề tài khoản</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-secondary small">Nội dung *</label>
                        <textarea name="message" rows="5"
                                  class="form-control bg-light border-light text-dark"
                                  placeholder="Mô tả vấn đề của bạn..." required></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-warning fw-bold px-4">
                            <i class="bi bi-send me-2"></i>Gửi yêu cầu
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Info Column -->
    <div class="col-md-5">
        <h2 class="h5 text-warning mb-4"><i class="bi bi-headset me-2"></i>THÔNG TIN LIÊN HỆ</h2>

        <div class="d-flex flex-column gap-3 mb-4">
            <div class="card bg-white border-light p-3 d-flex flex-row gap-3">
                <div class="flex-shrink-0 text-center" style="width:42px;">
                    <i class="bi bi-telephone-fill text-warning" style="font-size:1.3rem;"></i>
                </div>
                <div>
                    <strong class="text-dark d-block small">Hotline</strong>
                    <a href="tel:19001234" class="text-secondary text-decoration-none">1900 1234</a>
                    <small class="text-secondary d-block">Thứ 2 – CN, 8:00 – 22:00</small>
                </div>
            </div>
            <div class="card bg-white border-light p-3 d-flex flex-row gap-3">
                <div class="flex-shrink-0 text-center" style="width:42px;">
                    <i class="bi bi-envelope-fill text-warning" style="font-size:1.3rem;"></i>
                </div>
                <div>
                    <strong class="text-dark d-block small">Email</strong>
                    <a href="mailto:support@cinemax.vn" class="text-secondary text-decoration-none">support@cinemax.vn</a>
                    <small class="text-secondary d-block">Phản hồi trong 24h</small>
                </div>
            </div>
            <div class="card bg-white border-light p-3 d-flex flex-row gap-3">
                <div class="flex-shrink-0 text-center" style="width:42px;">
                    <i class="bi bi-chat-dots-fill text-warning" style="font-size:1.3rem;"></i>
                </div>
                <div>
                    <strong class="text-dark d-block small">Live Chat</strong>
                    <span class="text-secondary small">Khả dụng trên website & app</span>
                </div>
            </div>
        </div>

        <!-- FAQ quick links -->
        <div class="card bg-white border-light p-3">
            <h6 class="text-warning mb-3"><i class="bi bi-question-circle me-1"></i>Câu hỏi thường gặp</h6>
            <ul class="list-unstyled text-secondary small mb-0">
                <li class="mb-2"><i class="bi bi-chevron-right me-1 text-warning"></i>Làm thế nào để đặt vé?</li>
                <li class="mb-2"><i class="bi bi-chevron-right me-1 text-warning"></i>Chính sách đổi/trả vé như thế nào?</li>
                <li class="mb-2"><i class="bi bi-chevron-right me-1 text-warning"></i>Tôi quên mật khẩu, phải làm gì?</li>
                <li class="mb-0"><i class="bi bi-chevron-right me-1 text-warning"></i>Làm thế nào để dùng mã khuyến mãi?</li>
            </ul>
        </div>
    </div>
</div>
