@model CinemaXNet.Application.ViewModels.MovieDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedDate = (DateOnly)(ViewBag.SelectedDate ?? DateOnly.FromDateTime(DateTime.Today));
    var daysOfWeek = new[] { "Chủ Nhật", "Thứ Hai", "Thứ Ba", "Thứ Tư", "Thứ Năm", "Thứ Sáu", "Thứ Bảy" };
}

<div class="position-relative py-5 px-3 px-md-5 rounded-4 overflow-hidden mb-5 shadow-lg" style="background: url('@(!string.IsNullOrEmpty(Model.PosterUrl) ? Model.PosterUrl : "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba")') center/cover;">
    <!-- Dark overlay -->
    <div class="position-absolute w-100 h-100 top-0 start-0" style="background: rgba(255,255,255,0.85);"></div>
    
    <div class="position-relative z-1">
        <div class="row g-4 mb-5">
            <!-- Cột trái: Poster với 3D tilt -->
            <div class="col-md-4 col-lg-3 text-center text-md-start">
                <div class="movie-card-3d">
                    <img src="@(!string.IsNullOrEmpty(Model.PosterUrl) ? Model.PosterUrl : "https://placehold.co/400x600/111/fff?text=No+Poster")"
                         class="img-fluid rounded-4 shadow-lg border border-light movie-card"
                         alt="@Model.Title"
                         data-tilt
                         style="max-height: 420px; object-fit: cover; width: 100%;">
                </div>
            </div>

    <!-- Cột phải: Thông tin chi tiết -->
    <div class="col-md-8 col-lg-9">
        <h1 class="display-5 fw-medium text-dark mb-3">@Model.Title</h1>
        
        <div class="d-flex flex-wrap gap-2 mb-4">
            @if (!string.IsNullOrEmpty(Model.AgeRating))
            {
                <span class="badge badge-@Model.AgeRating.ToLower() fs-6 p-2 rounded">
                    @Model.AgeRating
                </span>
            }
            <span class="badge bg-secondary fs-6 p-2 rounded">
                <i class="bi bi-clock me-1"></i> @Model.FormattedDuration
            </span>
            @if (!string.IsNullOrEmpty(Model.Genre))
            {
                <span class="badge bg-secondary fs-6 p-2 rounded">
                    <i class="bi bi-tag-fill me-1"></i> @Model.Genre
                </span>
            }
            @if (Model.ReviewCount > 0)
            {
                <span class="badge bg-dark fs-6 p-2 rounded text-warning border border-warning">
                    <i class="bi bi-star-fill me-1"></i> @Model.AverageRating.ToString("0.0") / 5 (@Model.ReviewCount)
                </span>
            }
            <span class="badge bg-white shadow-sm border border-light text-warning fs-6 p-2 rounded">
                @(Model.Status == "now_showing" ? "Đang chiếu" : (Model.Status == "coming_soon" ? "Sắp chiếu" : "Đã kết thúc"))
            </span>
        </div>

        <div class="mb-4">
            <button class="btn btn-outline-primary rounded-3 px-4" data-bs-toggle="modal" data-bs-target="#trailerModal">
                Xem Trailer
            </button>
        </div>

        <h5 class="text-warning border-start border-warning border-3 ps-2 mb-2 fw-medium">Mô tả phim</h5>
        <p class="text-dark-50 lh-lg mb-4" style="text-align: justify; color: #ced4da;">
            @Html.Raw((!string.IsNullOrEmpty(Model.Description) ? Model.Description.Replace("\n", "<br/>") : "Chưa có thông tin mô tả chi tiết cho bộ phim này."))
        </p>
    </div>
</div>

<!-- Lịch chiếu trượt ngang + Thẻ suất chiếu đẹp -->
<div class="card bg-white border border-light rounded p-4 shadow-lg">
    <h3 class="h4 text-warning border-start border-warning border-4 ps-3 fw-medium mb-4">
        <i class="bi bi-calendar3 me-2"></i>LỊCH CHIẾU & SUẤT CHIẾU
    </h3>

    <!-- Showtime cards (BookMyShow Style) -->
    <div class="showtimes-container mt-4 mb-5 border border-light rounded-4 overflow-hidden shadow-sm">
        @await Html.PartialAsync("_ShowtimesCGV", Model)
    </div>
</div>

<!-- Reviews Section -->
<div class="card bg-white border border-light rounded p-4 shadow-lg mt-4">
    <h3 class="h4 text-warning border-start border-warning border-4 ps-3 fw-medium mb-4">
        <i class="bi bi-star-fill me-2"></i>ĐÁNH GIÁ PHIM
    </h3>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <form method="POST" asp-controller="Reviews" asp-action="Submit" class="mb-4 bg-white shadow-sm p-3 rounded border border-light">
            @Html.AntiForgeryToken()
            <input type="hidden" name="MovieId" value="@Model.Id">
            <div class="mb-3">
                <label class="form-label text-dark">Đánh giá của bạn</label>
                <select name="Rating" class="form-select bg-white text-warning border-light" style="width: auto;">
                    <option value="5">★★★★★ (5 sao) - Tuyệt vời</option>
                    <option value="4">★★★★☆ (4 sao) - Rất tốt</option>
                    <option value="3">★★★☆☆ (3 sao) - Khá</option>
                    <option value="2">★★☆☆☆ (2 sao) - Trung bình</option>
                    <option value="1">★☆☆☆☆ (1 sao) - Tệ</option>
                </select>
            </div>
            <div class="mb-3">
                <textarea name="Comment" class="form-control bg-white text-dark border-light" rows="3" placeholder="Chia sẻ cảm nghĩ của bạn về bộ phim này..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i> Gửi đánh giá</button>
        </form>
    }
    else
    {
        <div class="alert bg-white shadow-sm text-dark border-light">
            Vui lòng <a href="/login" class="text-warning text-decoration-none fw-medium">đăng nhập</a> để viết đánh giá cho bộ phim này.
        </div>
    }

    <div class="reviews-list mt-4">
        @if (!Model.Reviews.Any())
        {
            <p class="text-secondary text-center py-3"><i class="bi bi-chat-square-text me-2"></i>Chưa có đánh giá nào cho phim này.</p>
        }
        else
        {
            foreach (var review in Model.Reviews)
            {
                <div class="review-item border-bottom border-light pb-3 mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="text-dark"><i class="bi bi-person-circle me-2 text-primary"></i>@review.User?.Username</strong>
                        <small class="text-secondary opacity-75">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <div class="text-primary mb-2 fs-5">
                        @for(int i = 1; i <= 5; i++)
                        {
                            <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                        }
                    </div>
                    <p class="text-secondary mb-0 opacity-75">@Html.Raw(review.Comment.Replace("\n", "<br/>"))</p>
                </div>
            }
        }
    </div>
</div>
    </div> <!-- End position-relative z-1 -->
</div> <!-- End wrapper container -->

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Check if user has already selected a tab manually to not override it on back navigation
            if (sessionStorage.getItem('province_auto_selected') === 'true') return;

            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(position => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    
                    fetch(`/api/cinemas/nearest?lat=${lat}&lng=${lng}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success && data.data.length > 0) {
                                const nearestProvince = data.data[0].province;
                                // Find the tab with this province
                                const tabs = document.querySelectorAll('#province-tabs .nav-link');
                                for (let tab of tabs) {
                                    if (tab.innerText.trim().includes(nearestProvince)) {
                                        tab.click();
                                        sessionStorage.setItem('province_auto_selected', 'true');
                                        break;
                                    }
                                }
                            }
                        })
                        .catch(err => console.error('Error fetching nearest province:', err));
                }, () => {
                    // Geolocation denied or failed, ignore
                });
            }
        });
    </script>
}
