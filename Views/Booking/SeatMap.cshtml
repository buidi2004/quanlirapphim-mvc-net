@model CinemaXNet.ViewModels.SeatMapViewModel
@{
    ViewData["Title"] = "Chọn ghế — " + Model.MovieTitle;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">
    <!-- Cột trái: Sơ đồ ghế -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-lg" style="background-color: #1a1a2e !important; border: 1px solid #2d2d44 !important;">
            <div class="card-header bg-white border-bottom border-light p-3">
                <h5 class="mb-1 text-warning fw-bold">
                    <i class="bi bi-grid-3x3-gap me-2"></i>CHỌN GHẾ NGỒI
                </h5>
                <small class="text-secondary d-block mt-1">
                    <strong>@Model.MovieTitle</strong> —
                    @Model.ShowDate.ToString("dd/MM/yyyy") lúc
                    <strong>@Model.StartTime.ToString("HH:mm")</strong>
                    | @Model.RoomName
                </small>
            </div>
            <div class="card-body p-4">
                @await Html.PartialAsync("_SeatMap", Model)
            </div>
        </div>
    </div>

    <!-- Cột phải: Thông tin đặt vé -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-lg sticky-top" style="top: 20px; background-color: #1a1a2e !important; border: 1px solid #2d2d44 !important;">
            <div class="card-header bg-white border-bottom border-light p-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-receipt me-2 text-warning"></i>THÔNG TIN ĐẶT VÉ</h5>
            </div>
            <div class="card-body p-4">
                <!-- Ghế đã chọn -->
                <div class="mb-4">
                    <label class="text-secondary small fw-bold">Ghế đã chọn:</label>
                    <div id="selected-seats-display" class="mt-2 p-2 bg-light rounded d-flex flex-wrap gap-1 align-items-center"
                         style="min-height: 48px; border: 1px dashed #444;">
                        <span class="text-secondary fst-italic">Chưa chọn ghế</span>
                    </div>
                </div>

                <!-- Tổng tiền -->
                <div class="d-flex justify-content-between mb-3 border-bottom border-light pb-2">
                    <span class="text-secondary">Đơn giá:</span>
                    <span class="text-warning fw-bold" data-price-per-seat="@Model.PricePerSeat">
                        @Model.PricePerSeat.ToString("N0")₫ / ghế
                    </span>
                </div>
                <div class="d-flex justify-content-between mb-3 border-bottom border-light pb-2">
                    <span class="text-secondary">Số lượng:</span>
                    <span id="seat-count" class="text-dark fw-bold">0</span>
                </div>
                <div class="d-flex justify-content-between mb-4">
                    <span class="text-dark fw-bold fs-5">TỔNG CỘNG:</span>
                    <span id="total-price" class="text-warning fw-bold fs-4">0₫</span>
                </div>

                <!-- Form giữ ghế -->
                <form id="booking-form" method="post" action="/booking/hold">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="showtimeId" value="@Model.ShowtimeId">

                    @if (User.Identity == null || !User.Identity.IsAuthenticated)
                    {
                        <div class="mb-3">
                            <label class="form-label text-warning small fw-bold">Email (Khách)</label>
                            <input type="email" name="guestEmail" class="form-control bg-light border-0 text-dark" required placeholder="Nhập email để nhận vé...">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-warning small fw-bold">Số điện thoại</label>
                            <input type="tel" name="guestPhone" class="form-control bg-light border-0 text-dark" required placeholder="Nhập số điện thoại...">
                        </div>
                    }

                    <button type="submit" id="btn-hold"
                            class="btn btn-warning w-100 btn-lg fw-bold py-3 shadow" disabled>
                        <i class="bi bi-lock me-2"></i>GIỮ GHẾ (15 PHÚT)
                    </button>
                </form>

                <p class="text-secondary small text-center mt-3 mb-0">
                    <i class="bi bi-shield-check text-success me-1"></i>
                    Ghế được khóa giữ chỗ trong 15 phút sau khi xác nhận
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Sticky Checkout — Mobile only -->
<div class="sticky-checkout" id="sticky-checkout">
    <div class="checkout-info">
        <div>
            <span class="text-secondary small" id="sticky-seat-info">Chưa chọn ghế</span>
            <span class="total-price d-block" id="sticky-total-price">0₫</span>
        </div>
        <button class="btn btn-warning fw-bold px-4" id="sticky-btn-hold" disabled
                onclick="document.getElementById('booking-form').requestSubmit();">
            <i class="bi bi-lock me-2"></i>Giữ Ghế
        </button>
    </div>
</div>
