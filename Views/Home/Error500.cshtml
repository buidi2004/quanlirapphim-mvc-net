@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex flex-column align-items-center justify-content-center text-center py-5" style="min-height: 70vh;">
    <div class="position-relative mb-4">
        <!-- Đứt phim -->
        <i class="bi bi-film text-danger opacity-25" style="font-size: 8rem;"></i>
        <div class="position-absolute top-50 start-50 translate-middle">
            <h1 class="display-1 fw-bold text-danger mb-0" style="text-shadow: 2px 2px 8px rgba(220,53,69,0.3);">500</h1>
        </div>
    </div>
    
    <h2 class="text-white fw-bold mb-3">Hệ thống đang bảo trì cuộn phim!</h2>
    <p class="text-secondary fs-5 mb-5 max-w-md mx-auto">
        Đã có sự cố kỹ thuật xảy ra trong quá trình xử lý yêu cầu của bạn. Kỹ thuật viên của chúng tôi đang tiến hành khắc phục sự cố đứt phim này.
    </p>
    
    <div class="d-flex gap-3">
        <a href="/" class="btn btn-warning btn-lg fw-bold px-4 shadow-sm">
            <i class="bi bi-house-door me-2"></i>Về Trang chủ
        </a>
        <a href="/contact" class="btn btn-outline-secondary btn-lg fw-bold px-4">
            <i class="bi bi-envelope me-2"></i>Báo lỗi
        </a>
    </div>
</div>

<style>
    .max-w-md { max-width: 600px; }
</style>
