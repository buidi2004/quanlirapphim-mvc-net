@{
    ViewData["Title"] = "Tin tức";
    var featured = ViewBag.Featured as CinemaXNet.ViewModels.NewsItemViewModel;
    var articles = ViewBag.Articles as List<CinemaXNet.ViewModels.NewsItemViewModel> ?? [];
}

<!-- Featured -->
@if (featured != null)
{
    <div class="position-relative rounded-3 overflow-hidden mb-5 shadow-lg"
         style="height:350px; cursor:pointer;" onclick="location.href='/news/@featured.Slug'">
        <img src="@(featured.ImageUrl ?? "https://images.unsplash.com/photo-1536440136628-849c177e76a1?q=80&w=1200")"
             class="w-100 h-100" style="object-fit:cover; filter:brightness(.45);">
        <div class="position-absolute bottom-0 start-0 end-0 p-4"
             style="background:linear-gradient(transparent,rgba(0,0,0,.9));">
            <span class="badge bg-warning text-dark mb-2">@featured.Category</span>
            <h1 class="h3 text-white fw-bold mb-2">@featured.Title</h1>
            <p class="text-secondary mb-0">@featured.Summary</p>
        </div>
    </div>
}

<!-- Article grid -->
<h2 class="h5 text-warning border-start border-warning border-4 ps-3 fw-bold mb-4">
    <i class="bi bi-newspaper me-2"></i>TIN TỨC MỚI NHẤT
</h2>

<div class="row g-4">
    @foreach (var article in articles)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white border-light h-100 news-card shadow"
                 onclick="location.href='/news/@article.Slug'"
                 style="cursor:pointer; transition:.2s;">
                <div style="height:180px; overflow:hidden;">
                    <img src="@(article.ImageUrl ?? "https://images.unsplash.com/photo-1478720568477-152d9b164e26?q=80&w=800")"
                         class="w-100 h-100" style="object-fit:cover; transition:.3s;">
                </div>
                <div class="card-body">
                    <span class="badge bg-secondary mb-2 small">@article.Category</span>
                    <h5 class="card-title text-dark fw-bold" style="font-size:.95rem; line-height:1.4;">
                        @article.Title
                    </h5>
                    <p class="card-text text-secondary small">@article.Summary</p>
                </div>
                <div class="card-footer bg-transparent border-light">
                    <a href="/news/@article.Slug" class="btn btn-outline-warning btn-sm">
                        Đọc tiếp <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
.news-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(255,193,7,.15) !important; }
.news-card:hover img { transform: scale(1.05); }
</style>
