@model IEnumerable<CinemaXNet.Models.Domain.Cinema>
@{
    ViewData["Title"] = "Quản Lý Rạp Chiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var cinemas = Model?.ToList() ?? new List<CinemaXNet.Models.Domain.Cinema>();
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom border-light">
    <h1 class="h2 text-warning fw-bold">Quản Lý Rạp Chiếu</h1>
    <button type="button" class="btn btn-warning fw-bold btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#addCinemaModal">
        <i class="bi bi-plus-lg"></i> Thêm rạp mới
    </button>
</div>

<div class="card bg-white border border-light rounded shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead class="text-uppercase" style="background-color: #111;">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Tên Rạp</th>
                    <th scope="col">Thành phố</th>
                    <th scope="col">Địa chỉ</th>
                    <th scope="col">Điện thoại</th>
                    <th scope="col" class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!cinemas.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-secondary fst-italic">
                            Chưa có rạp nào.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var c in cinemas)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td><strong class="text-dark">@c.Name</strong></td>
                            <td>@c.Province</td>
                            <td>@c.Address</td>
                            <td>@c.Phone</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#editCinemaModal-@c.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCinemaModal-@c.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- Edit Modal -->
                        <div class="modal fade" id="editCinemaModal-@c.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content bg-light text-dark border border-light shadow-lg">
                                    <div class="modal-header bg-white border-bottom border-light">
                                        <h5 class="modal-title text-warning fw-bold">Sửa Rạp: @c.Name</h5>
                                        <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post" action="/admin/cinemas/update">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <div class="modal-body p-4 text-start">
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Tên Rạp</label>
                                                <input type="text" name="name" value="@c.Name" class="form-control bg-white text-dark border-light" required>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Tỉnh/Thành phố</label>
                                                <input type="text" name="province" value="@c.Province" class="form-control bg-white text-dark border-light" required>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Địa chỉ</label>
                                                <input type="text" name="address" value="@c.Address" class="form-control bg-white text-dark border-light" required>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Điện thoại</label>
                                                <input type="text" name="phone" value="@c.Phone" class="form-control bg-white text-dark border-light">
                                            </div>
                                        </div>
                                        <div class="modal-footer bg-white border-top border-light">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-info fw-bold">Cập nhật</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Delete Modal -->
                        <div class="modal fade" id="deleteCinemaModal-@c.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content bg-light text-dark border border-light shadow-lg">
                                    <div class="modal-header bg-white border-bottom border-light">
                                        <h5 class="modal-title text-danger fw-bold">Xác Nhận Xóa</h5>
                                        <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4 text-start">
                                        Bạn có chắc chắn muốn xóa rạp <strong>@c.Name</strong>?
                                    </div>
                                    <div class="modal-footer bg-white border-top border-light">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                        <form method="post" action="/admin/cinemas/delete">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button type="submit" class="btn btn-danger fw-bold">Xóa</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addCinemaModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-light text-dark border border-light shadow-lg">
            <div class="modal-header bg-white border-bottom border-light">
                <h5 class="modal-title text-warning fw-bold">Thêm Rạp Mới</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/admin/cinemas">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 text-start">
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Tên Rạp</label>
                        <input type="text" name="name" class="form-control bg-white text-dark border-light" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Tỉnh/Thành phố</label>
                        <input type="text" name="province" class="form-control bg-white text-dark border-light" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Địa chỉ</label>
                        <input type="text" name="address" class="form-control bg-white text-dark border-light" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Điện thoại</label>
                        <input type="text" name="phone" class="form-control bg-white text-dark border-light">
                    </div>
                </div>
                <div class="modal-footer bg-white border-top border-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning fw-bold">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>
