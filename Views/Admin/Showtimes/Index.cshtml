@model IEnumerable<CinemaXNet.Domain.Entities.Showtime>
@{
    ViewData["Title"] = "Quản Lý Suất Chiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var showtimes = Model?.ToList() ?? new List<CinemaXNet.Domain.Entities.Showtime>();
    var movies = ViewBag.Movies as IEnumerable<CinemaXNet.Domain.Entities.Movie> ?? new List<CinemaXNet.Domain.Entities.Movie>();
    var rooms = ViewBag.Rooms as IEnumerable<CinemaXNet.Domain.Entities.Room> ?? new List<CinemaXNet.Domain.Entities.Room>();
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom border-light">
    <h1 class="h2 text-warning fw-bold">Quản Lý Suất Chiếu</h1>
    <button type="button" class="btn btn-warning fw-bold btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#addShowtimeModal">
        <i class="bi bi-plus-lg"></i> Thêm suất chiếu mới
    </button>
</div>

<div class="card bg-white border border-light rounded shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead class="text-uppercase" style="background-color: #111;">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Phim</th>
                    <th scope="col">Rạp / Phòng</th>
                    <th scope="col">Ngày chiếu</th>
                    <th scope="col">Thời gian</th>
                    <th scope="col">Giá vé</th>
                    <th scope="col" class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!showtimes.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-secondary fst-italic">
                            Chưa có suất chiếu nào.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var s in showtimes)
                    {
                        <tr>
                            <td>@s.Id</td>
                            <td><strong class="text-dark">@s.Movie?.Title</strong></td>
                            <td>@s.Room?.Cinema?.Name - @s.Room?.Name</td>
                            <td>@s.ShowDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-secondary">@s.StartTime.ToString("HH:mm") - @s.EndTime?.ToString("HH:mm")</span></td>
                            <td>@string.Format("{0:N0}₫", s.Price)</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#editShowtimeModal-@s.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteShowtimeModal-@s.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- Edit Modal -->
                        <div class="modal fade" id="editShowtimeModal-@s.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content bg-light text-dark border border-light shadow-lg">
                                    <div class="modal-header bg-white border-bottom border-light">
                                        <h5 class="modal-title text-warning fw-bold">Sửa Suất Chiếu</h5>
                                        <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post" action="/admin/showtimes/update">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <div class="modal-body p-4 text-start">
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Phim</label>
                                                <select name="movieId" class="form-select bg-white text-dark border-light" required>
                                                    @foreach(var m in movies) {
                                                        <option value="@m.Id" selected="@(m.Id == s.MovieId)">@m.Title</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label text-dark fw-bold">Phòng chiếu</label>
                                                <select name="roomId" class="form-select bg-white text-dark border-light" required>
                                                    @foreach(var r in rooms) {
                                                        <option value="@r.Id" selected="@(r.Id == s.RoomId)">@r.Cinema?.Name - @r.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="row g-3 mb-3">
                                                <div class="col-md-6">
                                                    <label class="form-label text-dark fw-bold">Ngày chiếu</label>
                                                    <input type="date" name="showDate" value="@s.ShowDate.ToString("yyyy-MM-dd")" class="form-control bg-white text-dark border-light" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label text-dark fw-bold">Giá vé</label>
                                                    <input type="number" name="price" value="@s.Price" class="form-control bg-white text-dark border-light" required>
                                                </div>
                                            </div>
                                            <div class="row g-3 mb-3">
                                                <div class="col-md-6">
                                                    <label class="form-label text-dark fw-bold">Giờ bắt đầu</label>
                                                    <input type="time" name="startTime" value="@s.StartTime.ToString("HH:mm")" class="form-control bg-white text-dark border-light" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label text-dark fw-bold">Giờ kết thúc</label>
                                                    <input type="time" name="endTime" value="@s.EndTime?.ToString("HH:mm")" class="form-control bg-white text-dark border-light" required>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer bg-white border-top border-light">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-info fw-bold">Cập nhật</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Delete Modal -->
                        <div class="modal fade" id="deleteShowtimeModal-@s.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content bg-light text-dark border border-light shadow-lg">
                                    <div class="modal-header bg-white border-bottom border-light">
                                        <h5 class="modal-title text-danger fw-bold">Xác Nhận Xóa</h5>
                                        <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4 text-start">
                                        Bạn có chắc chắn muốn xóa suất chiếu này? Hành động này có thể ảnh hưởng đến vé đã đặt.
                                    </div>
                                    <div class="modal-footer bg-white border-top border-light">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                        <form method="post" action="/admin/showtimes/delete">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <button type="submit" class="btn btn-danger fw-bold">Xóa</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </tbody>
        </table>
    </div>
    
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top border-light d-flex justify-content-center">
            <ul class="pagination pagination-sm mb-0">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="/admin/showtimes?page=@i">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>

<!-- Add Modal -->
<div class="modal fade" id="addShowtimeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-light text-dark border border-light shadow-lg">
            <div class="modal-header bg-white border-bottom border-light">
                <h5 class="modal-title text-warning fw-bold">Thêm Suất Chiếu Mới</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/admin/showtimes">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 text-start">
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Phim</label>
                        <select name="movieId" class="form-select bg-white text-dark border-light" required>
                            @foreach(var m in movies) {
                                <option value="@m.Id">@m.Title</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Phòng chiếu</label>
                        <select name="roomId" class="form-select bg-white text-dark border-light" required>
                            @foreach(var r in rooms) {
                                <option value="@r.Id">@r.Cinema?.Name - @r.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-dark fw-bold">Ngày chiếu</label>
                            <input type="date" name="showDate" class="form-control bg-white text-dark border-light" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-dark fw-bold">Giá vé</label>
                            <input type="number" name="price" value="85000" class="form-control bg-white text-dark border-light" required>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-dark fw-bold">Giờ bắt đầu</label>
                            <input type="time" name="startTime" class="form-control bg-white text-dark border-light" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-dark fw-bold">Giờ kết thúc</label>
                            <input type="time" name="endTime" class="form-control bg-white text-dark border-light" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top border-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning fw-bold">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>
