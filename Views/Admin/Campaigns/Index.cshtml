@model CinemaXNet.Application.ViewModels.PaginatedList<dynamic>
@{
    ViewData["Title"] = "Chiến dịch Marketing";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var campaigns = Model?.Items ?? new List<dynamic>();
}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom border-light">
    <h1 class="h2 text-warning fw-medium">Chiến Dịch Marketing</h1>
    <button class="btn btn-primary fw-medium btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#addCampaignModal">
        <i class="bi bi-plus-lg"></i> Lên lịch chiến dịch
    </button>
</div>

<div class="card bg-white border border-light rounded shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="text-uppercase" class="table-light">
                <tr>
                    <th scope="col">Tên Chiến Dịch</th>
                    <th scope="col">Loại</th>
                    <th scope="col">Đối tượng</th>
                    <th scope="col">Ngày lên lịch</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Đã gửi</th>
                </tr>
            </thead>
            <tbody>
                @if (!campaigns.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">Chưa có chiến dịch nào.</td></tr>
                }
                else
                {
                    foreach (var camp in campaigns)
                    {
                        <tr>
                            <td><strong class="text-white">@camp.name</strong></td>
                            <td>
                                @if (camp.type == "Email") { <span class="badge bg-primary">Email</span> }
                                else { <span class="badge bg-success">SMS</span> }
                            </td>
                            <td>@camp.target_audience</td>
                            <td>@camp.scheduled_at</td>
                            <td>
                                @if (camp.status == "Sent") { <span class="badge bg-success">Đã gửi xong</span> }
                                else if (camp.status == "Scheduled") { <span class="badge bg-warning text-white">Đã lên lịch</span> }
                                else { <span class="badge bg-secondary">Bản nháp</span> }
                            </td>
                            <td>@camp.sent_count khách hàng</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", Model)
</div>

<!-- Add Modal -->
<div class="modal fade" id="addCampaignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-light text-dark border border-light shadow-lg">
            <div class="modal-header bg-white border-bottom border-light">
                <h5 class="modal-title text-warning fw-medium">Lên lịch chiến dịch mới</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/admin/campaigns">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 text-start">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Tên chiến dịch</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Loại thông báo</label>
                        <select name="type" class="form-select">
                            <option value="Email">Gửi Email</option>
                            <option value="SMS">Gửi SMS</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Tập khách hàng</label>
                        <select name="targetAudience" class="form-select">
                            <option value="All">Tất cả khách hàng</option>
                            <option value="VIP">Khách hàng VIP (Gold, Diamond)</option>
                            <option value="Inactive">Khách hàng lâu chưa mua</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Thời gian gửi dự kiến</label>
                        <input type="datetime-local" name="scheduledAt" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Nội dung</label>
                        <textarea name="content" class="form-control" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top border-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-medium">Lên lịch gửi</button>
                </div>
            </form>
        </div>
    </div>
</div>
