@model CinemaXNet.ViewModels.PaginatedList<dynamic>
@{
    ViewData["Title"] = "Quản Lý Vé Đã Đặt";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var tickets = Model?.Items ?? new List<dynamic>();
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom border-light">
    <h1 class="h2 text-warning fw-bold">Quản Lý Vé Đã Đặt</h1>
</div>

<div class="card bg-white border border-light rounded shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead class="text-uppercase" style="background-color: #111;">
                <tr>
                    <th scope="col">Mã Vé</th>
                    <th scope="col">Người dùng</th>
                    <th scope="col">Phim</th>
                    <th scope="col">Ngày chiếu</th>
                    <th scope="col">Tổng tiền</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Ngày đặt</th>
                </tr>
            </thead>
            <tbody>
                @if (!tickets.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-secondary fst-italic">
                            Chưa có dữ liệu vé.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var t in tickets)
                    {
                        <tr>
                            <td><strong class="text-dark">@t.ticket_code</strong></td>
                            <td>
                                <div>@t.full_name</div>
                                <small class="text-secondary">@t.email</small>
                            </td>
                            <td>@t.MovieTitle</td>
                            <td>
                                @if (t.show_date != null)
                                {
                                    <div>@Convert.ToDateTime(t.show_date).ToString("dd/MM/yyyy")</div>
                                    <small class="text-secondary">@t.start_time</small>
                                }
                            </td>
                            <td class="text-success fw-bold">@string.Format("{0:N0}₫", t.total_price)</td>
                            <td>
                                @if (t.status == "paid")
                                {
                                    <span class="badge bg-success">Đã thanh toán</span>
                                }
                                else if (t.status == "pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã hủy</span>
                                }
                            </td>
                            <td>@Convert.ToDateTime(t.created_at).ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", Model)
</div>
